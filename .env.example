# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Max API (vk.com)
MAX_ACCESS_TOKEN=your_max_access_token_here

# Database
DATABASE_URL=postgresql+asyncpg://maxrepost:maxrepost@localhost:5432/maxrepost

# Redis
REDIS_URL=redis://localhost:6379/0

# YooKassa Payment
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key

# Logging
LOG_LEVEL=INFO
DEBUG=false

# Rate Limiting
MAX_RPS=25

# Bonus Channel (for subscription check)
BONUS_CHANNEL=@your_bonus_channel

# Pricing
PRICE_PER_POST=3
FREE_POSTS_BONUS=10
